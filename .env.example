# Copy this file to .env and fill local values. Do not commit .env.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ASR_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# Translation / TTS
TRANSLATION_STYLE=general
TTS_PROVIDER=openai
TTS_VOICE_LABEL=OpenAI nova
TTS_SYNC_MODE=balanced
TTS_START_OFFSET_MS=250
TTS_MAX_SPEED=1.8
TTS_BLOCK_MAX_CHARS=320
TTS_MIN_SLOT_SECONDS=0.35
EDGE_TTS_VOICE=vi-VN-HoaiMyNeural

# Douyin / browser cookies
DOUYIN_COOKIE=
DOUYIN_COOKIE_FILE=
DOUYIN_COOKIES_FROM_BROWSER=

# Paths
DOWNLOADS_DIR=downloads
OUTPUT_DIR=output
DATABASE_PATH=data/app.db
LOGS_DIR=logs
STATE_FILE=download_state.json
METADATA_FILE=metadata.json
FFMPEG_PATH=
FFPROBE_PATH=

# Pipeline behavior
MAX_RETRIES=5
DOWNLOAD_CONCURRENCY=1
TRANSLATION_CONCURRENCY=4
MAX_FILENAME_LEN=180
SOCKET_TIMEOUT=30
CONCURRENT_FRAGMENTS=4
DEDUPE_BY_HASH=0